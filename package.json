{
  "name": "pw",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "lint:js": "eslint . --cache",
    "lint:css": "stylelint \"**/*.css\" --cache",
    "lint:html": "htmlhint \"**/*.html\"",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "check": "npm run format:check && npm run lint",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glenn-psd/glenn-psd.github.io.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/glenn-psd/glenn-psd.github.io/issues"
  },
  "homepage": "https://github.com/glenn-psd/glenn-psd.github.io#readme",
  "devDependencies": {
    "eslint": "^9.29.0",
    "htmlhint": "^1.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "stylelint": "^16.20.0",
    "stylelint-config-standard": "^38.0.0"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --cache --fix"
    ],
    "*.css": [
      "prettier --write",
      "stylelint --cache --fix"
    ],
    "*.html": [
      "prettier --write",
      "htmlhint"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
